# Provenn AI environment

# AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Session + encryption
COOKIE_SECRET=replace-with-long-random-string
ENCRYPTION_KEY=replace-with-another-long-random-string

# Optional Redis retention (falls back to in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Monad
# Hardhat deploy reads these from .env / .env.local automatically.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
MONAD_CONTRACT_ADDRESS=
MONAD_EXPLORER_URL=https://testnet.monadexplorer.com
# 0x-prefixed private key of a faucet-funded Monad testnet wallet
MANAGED_WALLET_PRIVATE_KEY=

# Public client mirrors (optional — /api/chain also serves server MONAD_* values to the wallet flow)
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_CHAIN_ID=10143
NEXT_PUBLIC_MONAD_CONTRACT_ADDRESS=
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://testnet.monadexplorer.com

# Cloudflare Turnstile (optional in local; required for managed proofs when secret is set)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
